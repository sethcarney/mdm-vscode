{
  "name": "mdm-sidebar",
  "displayName": "MDM",
  "description": "VS Code extension for the MDM CLI tool — browse Skills and Agents from the sidebar.",
  "version": "1.1.0",
  "publisher": "SethsSoftware",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sethcarney/mdm-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/sethcarney/mdm-vscode/issues"
  },
  "homepage": "https://github.com/sethcarney/mdm-vscode#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "resources/mdm.png",
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "mdm",
    "cli",
    "skills",
    "agents",
    "management"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "MDM",
      "properties": {
        "mdm.cliPath": {
          "type": "string",
          "default": "mdm",
          "markdownDescription": "Path to the `mdm` CLI executable. Defaults to `\"mdm\"`, which assumes the binary is in your `PATH`."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mdm-explorer",
          "title": "MDM",
          "icon": "resources/mdm.svg"
        }
      ]
    },
    "views": {
      "mdm-explorer": [
        {
          "id": "mdmSkills",
          "name": "Skills",
          "contextualTitle": "MDM Skills"
        },
        {
          "id": "mdmRules",
          "name": "Rules",
          "contextualTitle": "MDM Rules"
        },
        {
          "id": "mdmAgents",
          "name": "Agents",
          "contextualTitle": "MDM Agents"
        }
      ]
    },
    "commands": [
      {
        "command": "mdm.refreshSkills",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "mdm.refreshAgents",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "mdm.refreshAll",
        "title": "MDM: Refresh All Views",
        "icon": "$(refresh)"
      },
      {
        "command": "mdm.copyName",
        "title": "Copy Name"
      },
      {
        "command": "mdm.doctor",
        "title": "MDM Doctor",
        "icon": "$(pulse)"
      },
      {
        "command": "mdm.installSkills",
        "title": "Install Configured Project Skills",
        "icon": "$(cloud-download)"
      },
      {
        "command": "mdm.findSkill",
        "title": "Find Skill",
        "icon": "$(search)"
      },
      {
        "command": "mdm.addSkill",
        "title": "Add Skill",
        "icon": "$(add)"
      },
      {
        "command": "mdm.updateAllSkills",
        "title": "Update All Skills",
        "icon": "$(sync)"
      },
      {
        "command": "mdm.auditSkills",
        "title": "Audit Skills",
        "icon": "$(shield)"
      },
      {
        "command": "mdm.updateSkill",
        "title": "Update Skill",
        "icon": "$(cloud-download)"
      },
      {
        "command": "mdm.deleteSkill",
        "title": "Remove Skill",
        "icon": "$(trash)"
      },
      {
        "command": "mdm.addAgent",
        "title": "Add Agent",
        "icon": "$(add)"
      },
      {
        "command": "mdm.deleteAgent",
        "title": "Remove Agent",
        "icon": "$(trash)"
      },
      {
        "command": "mdm.refreshRules",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "mdm.rulesLinkAgent",
        "title": "Link Agent Rules",
        "icon": "$(link)"
      },
      {
        "command": "mdm.rulesLink",
        "title": "Link",
        "icon": "$(link)"
      },
      {
        "command": "mdm.rulesUnlink",
        "title": "Unlink",
        "icon": "$(debug-disconnect)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mdm.findSkill",
          "when": "view == mdmSkills",
          "group": "navigation@1"
        },
        {
          "command": "mdm.addSkill",
          "when": "view == mdmSkills",
          "group": "navigation@2"
        },
        {
          "command": "mdm.updateAllSkills",
          "when": "view == mdmSkills",
          "group": "navigation@3"
        },
        {
          "command": "mdm.refreshSkills",
          "when": "view == mdmSkills",
          "group": "navigation@4"
        },
        {
          "command": "mdm.addAgent",
          "when": "view == mdmAgents",
          "group": "navigation@1"
        },
        {
          "command": "mdm.refreshAgents",
          "when": "view == mdmAgents",
          "group": "navigation@2"
        },
        {
          "command": "mdm.rulesLinkAgent",
          "when": "view == mdmRules",
          "group": "navigation@1"
        },
        {
          "command": "mdm.refreshRules",
          "when": "view == mdmRules",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "mdm.updateSkill",
          "when": "viewItem == mdm-skill",
          "group": "inline@1"
        },
        {
          "command": "mdm.deleteSkill",
          "when": "viewItem == mdm-skill",
          "group": "inline@2"
        },
        {
          "command": "mdm.deleteAgent",
          "when": "viewItem == mdm-agent",
          "group": "inline@1"
        },
        {
          "command": "mdm.auditSkills",
          "when": "viewItem == mdm-skill",
          "group": "context@1"
        },
        {
          "command": "mdm.copyName",
          "when": "viewItem == mdm-skill || viewItem == mdm-agent",
          "group": "context@2"
        },
        {
          "command": "mdm.rulesLink",
          "when": "viewItem == mdm-rule-missing",
          "group": "inline@1"
        },
        {
          "command": "mdm.rulesUnlink",
          "when": "viewItem == mdm-rule-linked",
          "group": "inline@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3"
  }
}
